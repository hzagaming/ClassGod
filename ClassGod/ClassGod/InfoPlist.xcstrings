      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod benötigt die Barrierefreiheitsberechtigung um den Browser im Vordergrund zu erkennen und zu bestimmten Tabs zu wechseln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
