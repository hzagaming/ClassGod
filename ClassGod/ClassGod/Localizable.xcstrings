    "reset.confirm.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Einstellungen werden auf die Standardwerte zurückgesetzt. Deine gespeicherten Tabs sind davon nicht betroffen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will reset all settings to their default values. Your saved tabs will not be affected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los ajustes se restablecerán a sus valores predeterminados. Tus pestañas guardadas no se verán afectadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tous les réglages seront réinitialisés aux valeurs par défaut. Tes onglets enregistrés ne seront pas affectés."
