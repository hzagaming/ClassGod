    "plist.accessibility" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod benötigt die Barrierefreiheitsberechtigung um den Browser im Vordergrund zu erkennen und zu bestimmten Tabs zu wechseln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod needs Accessibility permission to detect the frontmost browser and switch to specific tabs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod necesita permiso de Accesibilidad para detectar el navegador al frente y cambiar a pestañas específicas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod a besoin de la permission Accessibilité pour détecter le navigateur au premier plan et basculer vers des onglets spécifiques."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod は最前面のブラウザを検出して特定のタブに切り替えるために、アクセシビリティ権限が必要だ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod 는 맨 앞 브라우저를 감지하고 특정 탭으로 전환하기 위해 접근성 권한이 필요해."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod precisa de permissão de Acessibilidade para detectar o navegador em primeiro plano e alternar para abas específicas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod требуется разрешение Специальных возможностей для обнаружения браузера на переднем плане и переключения на конкретные вкладки."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod 需要 Accessibility 權限來探測最前面的瀏覽器並切換到指定標籤。"
          }
        }
      }
    },
