    "clear.confirm.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle gespeicherten Tabs und Tastenkürzel werden dauerhaft gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all saved tabs and shortcuts. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas las pestañas y atajos guardados se eliminarán permanentemente. No se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tous les onglets et raccourcis enregistrés seront définitivement supprimés. Action irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存済みの全タブとショートカットが永久に削除される。元に戻せない。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저장된 모든 탭과 단축키가 영구 삭제돼. 되돌릴 수 없어."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas as abas e atalhos salvos serão permanentemente apagados. Não pode ser desfeito."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все сохранённые вкладки и горячие клавиши будут безвозвратно удалены. Это нельзя отменить."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會永久刪除所有保存的頁面和快捷鍵，刪了就沒了。"
          }
        }
      }
    },
