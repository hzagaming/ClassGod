    "delete.confirm.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bist du sicher, dass du \"%@\" löschen willst? Wenn der Lehrer kommt, kannst du nicht mehr wechseln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete \"%@\"? You won't be able to switch when the teacher comes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres borrar \"%@\"? Cuando venga el profe no podrás cambiar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu es sûr de vouloir supprimer \"%@\" ? Tu pourras plus changer quand le prof arrive."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本当に \"%@\" を削除する？削除したら先生が来たとき切り替えられないぞ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "정말 \"%@\" 를 지울 거야? 지우면 선생님 왔을 때 못 바꿔"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza que quer apagar \"%@\"? Quando o professor vier não vai conseguir trocar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Точно удалить \"%@\"? Когда учитель придёт, не сможешь переключить."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確定要刪 \"%@\" 嗎？刪了老師來了就沒法切了"
          }
        }
      }
    },
