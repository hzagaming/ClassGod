    "empty.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klick unten auf \"Aktuellen Tab speichern\" um die Seite zu speichern, damit du umschalten kannst wenn der Lehrer kommt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click \"Save Current Tab\" below to save the current webpage, so you can switch instantly when the teacher comes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz clic en \"Guardar pestaña actual\" abajo para guardar la página, así podrás cambiar al instante cuando venga el profe."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique sur \"Enregistrer l'onglet actuel\" en bas pour sauvegarder la page, comme ça tu pourras switch instantanément quand le prof arrive."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下の\"現在のタブを保存\"をクリックして今のページを保存しとけ、先生が来たら一発で切り替えられるぞ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아래 \"현재 페이지 저장\"을 눌러서 지금 웹페이지를 저장해둬, 선생님 오면 순식간에 바꿀 수 있어"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique em \"Salvar aba atual\" abaixo para salvar a página, assim você pode trocar na hora quando o professor chegar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажми \"Сохранить текущую вкладку\" снизу, чтобы сохранить страницу, и сможешь мгновенно переключить когда учитель придёт."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點下面的\"保存當前頁面\"把當前網頁存下來，老師來了好秒切"
          }
        }
      }
    },
