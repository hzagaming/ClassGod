    "permission.required.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie soll ich ohne Barrierefreiheitsberechtigung Wache halten? Geh zu Systemeinstellungen > Datenschutz & Sicherheit > Bedienungshilfen und schalte es ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How am I supposed to keep watch without Accessibility permission? Go to System Settings > Privacy & Security > Accessibility and turn it on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Cómo voy a vigilar sin permiso de Accesibilidad? Ve a Ajustes del Sistema > Privacidad y Seguridad > Accesibilidad y actívalo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment je suis censé faire le guet sans la permission Accessibilité ? Va dans Réglages Système > Confidentialité et sécurité > Accessibilité et active-la."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アクセシビリティ権限なしで見張りできるわけないだろ？システム設定 > プライバシーとセキュリティ > アクセシビリティ でオンにして"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "접근성 권한 없이 어떻게 감시하라고? 시스템 설정 > 개인정보 보호 및 보안 > 접근성 에서 켜줘"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como vou ficar de olho sem permissão de Acessibilidade? Vá em Ajustes do Sistema > Privacidade e Segurança > Acessibilidade e ative."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как я буду следить без разрешения Специальных возможностей? Зайди в Системные настройки > Конфиденциальность и безопасность > Специальные возможности и включи."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不給 Accessibility 權限我怎麼幫你放風？去 系統設定 > 隱私與安全性 > 輔助功能 裡打開"
          }
        }
      }
    },
