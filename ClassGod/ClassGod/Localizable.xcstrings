    "permission.alert.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod benötigt Barrierefreiheits- und Automatisierungsberechtigungen um Browser-Tabs zu erkennen und zu ihnen zu wechseln. Bitte erteile diese Berechtigungen in den Systemeinstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod needs Accessibility and Automation permissions to detect browser tabs and switch to them. Please grant these permissions in System Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod necesita permisos de Accesibilidad y Automatización para detectar pestañas del navegador y cambiar a ellas. Concede estos permisos en Ajustes del Sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod a besoin des permissions Accessibilité et Automatisation pour détecter les onglets du navigateur et y basculer. Accorde ces permissions dans les Réglages Système."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod はブラウザタブを検出して切り替えるために、アクセシビリティと自動化の権限が必要だ。システム設定で許可してくれ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod 가 브라우저 탭을 감지하고 전환하려면 접근성과 자동화 권한이 필요해. 시스템 설정에서 허용해줘."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod precisa de permissões de Acessibilidade e Automação para detectar abas do navegador e alternar para elas. Conceda essas permissões nos Ajustes do Sistema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod требуются разрешения Специальных возможностей и Автоматизации для обнаружения вкладок браузера и переключения на них. Предоставь эти разрешения в Системных настройках."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ClassGod 需要 Accessibility 和 Automation 權限才能幫你探測瀏覽器和切屏。去系統設定裡給一下。"
          }
        }
      }
    },
